{
  "name": "gradient-runtime",
  "version": "0.1.3",
  "description": "Standalone gradient animation runtime for the browser",
  "author": "oyaboon",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oyaboon/gradient.git",
    "directory": "packages/gradient-runtime"
  },
  "homepage": "https://gradient.oyaboon.com",
  "bugs": {
    "url": "https://github.com/oyaboon/gradient/issues"
  },
  "type": "module",
  "main": "./dist/gradient-runtime.esm.js",
  "module": "./dist/gradient-runtime.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/gradient-runtime.esm.js",
      "types": "./dist/index.d.ts"
    },
    "./global": {
      "import": "./dist/gradient-runtime.global.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/gradient-runtime.react.js",
      "types": "./dist/react.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "scripts": {
    "build": "node ../../scripts/build-runtime.mjs && node copy-to-dist.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "gradient",
    "canvas",
    "animation",
    "runtime"
  ],
  "license": "MIT"
}
