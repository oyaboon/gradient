# Database (Prisma + PostgreSQL)
DATABASE_URL="postgresql://user:password@host/dbname"

# Paddle Billing
PADDLE_API_KEY=pdl_...              # Server-side API key (Developer tools > Authentication)
PADDLE_WEBHOOK_SECRET=pdl_ntfset_...  # Webhook signing secret (Developer tools > Notifications)

# Client-side Paddle (NEXT_PUBLIC_ prefix exposes to browser)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=live_...  # Client-side token (Developer tools > Authentication)
NEXT_PUBLIC_PADDLE_PRICE_ID=pri_...       # Price ID (Products > Price in Paddle Dashboard)
